# Django
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
DJANGO_TIME_ZONE=America/Santiago
DJANGO_LANGUAGE_CODE=es-cl
DJANGO_STATIC_ROOT=/vol/web/static
DJANGO_MEDIA_ROOT=/vol/web/media

# Database / PostGIS
POSTGRES_DB=elbigotes
POSTGRES_USER=elbigotes
POSTGRES_PASSWORD=elbigotes
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
GEOCODING_PROVIDER=nominatim
GEOCODING_TIMEOUT=10
GEOCODING_USER_AGENT=elbigotes-backend/0.1

# Frontend / CORS
CORS_ALLOWED_ORIGINS=http://localhost:18080,http://localhost:3000
CORS_ALLOWED_ORIGIN_REGEXES=
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOW_CREDENTIALS=False
API_THROTTLE_ANON=120/hour
API_THROTTLE_USER=600/hour

# Frontend / Next.js
NEXT_PUBLIC_SITE_URL=http://localhost:18080
NEXT_PUBLIC_API_BASE_URL=/api/v1
# En Docker el frontend SSR debe pasar por nginx para conservar los headers HTTPS correctos.
INTERNAL_API_BASE_URL=http://nginx/api/v1
NEXT_PUBLIC_DEFAULT_LAT=-33.4489
NEXT_PUBLIC_DEFAULT_LNG=-70.6693
NEXT_PUBLIC_DEFAULT_ZOOM=11
NEXT_PUBLIC_USE_MOCKS=false

# Nginx / platform
APP_PORT=8000
GUNICORN_WORKERS=3
WEB_HOST_BIND=127.0.0.1
WEB_HOST_PORT=18000
NGINX_HOST_BIND=127.0.0.1
NGINX_HOST_PORT=18080
